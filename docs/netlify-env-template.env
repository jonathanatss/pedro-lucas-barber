# Netlify environment variables template
# Import this content in Netlify after replacing every placeholder:
# Project configuration > Environment variables > Add a variable > Import from a .env file

# Public site URL
NEXT_PUBLIC_SITE_URL=https://pedrolucasbarbearia.netlify.app

# Netlify secret scanning
# These values are intentionally public/non-secret and can appear in Next.js build output.
SECRETS_SCAN_OMIT_KEYS=ASAAS_ENVIRONMENT,BOOKING_TIMEZONE,NEXT_PUBLIC_SUPABASE_ANON_KEY,NEXT_PUBLIC_SITE_URL,NEXT_PUBLIC_SUPABASE_URL

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=SUA_SUPABASE_SERVICE_ROLE_KEY

# Booking / Google Calendar
BOOKING_TIMEZONE=America/Sao_Paulo
GOOGLE_CALENDAR_ID=SEU_CALENDAR_ID
GOOGLE_SERVICE_ACCOUNT_EMAIL=SUA_SERVICE_ACCOUNT@SEU-PROJETO.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_PRIVADA_AQUI\n-----END PRIVATE KEY-----\n"

# Asaas recurring billing
ASAAS_ENVIRONMENT=production
ASAAS_API_KEY=SUA_ASAAS_API_KEY_PRODUCAO
ASAAS_WEBHOOK_TOKEN=COLE_AQUI_UM_TOKEN_FORTE_COM_PELO_MENOS_32_CARACTERES
